class Solution {
    public boolean checkIfPangram(String sentence) {
       boolean arr[] = new boolean[26]; 

        int num ;
       for(int i=0; i<sentence.length(); i++){
            char ch = sentence.charAt(i);
            num = ch - 97;
            arr[num] = true;
        }

        for(int j=0; j<26; j++){
            if(arr[j] == false){
                return false;
            }
        }
        return true;
    }
}
