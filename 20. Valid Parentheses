class Solution {
    public boolean isValid(String s) {
        int n = s.length()/2;
        int count = 0; 
        for(int i=n-1; i>=0; i--){
            for(int j=n; j<s.length(); j++){
                if( s.charAt(i) == s.charAt(j)){
                    count +=2;
                    
                }
            }
        }
        if(count != s.length()){
            return false;
        }
        return true;
    }
}
