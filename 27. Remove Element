class Solution {
    public int removeElement(int[] nums, int val) {
        Arrays.sort(nums); 
       
        int k=-1;
        for(int i=0; i<nums.length; i++){
           
            if(nums[i] != val){
                k++;
                nums[k] = nums[i];
            } 
        }
        return k+1;
    }
}
