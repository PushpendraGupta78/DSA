class Solution {
    public int[] numberGame(int[] nums) {
        int newnum[] = new int[nums.length];
        Arrays.sort(nums);
        for(int i=0; i<nums.length; i++){
            int temp = nums[i+1];
                newnum[i+1] = nums[i]; 
                newnum[i] = temp;
                i++;
        }
        return newnum;
