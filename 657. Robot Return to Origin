class Solution {
    public boolean judgeCircle(String moves) {
        int U = 0;
        int D = 0;
        int R = 0;
        int L = 0;

        for(int i=0; i<moves.length(); i++){
            char dir = moves.charAt(i);
            if(dir == 'U'){
                U++;
            } else if (dir == 'D'){
                D++;
            }else if (dir == 'R'){
                R++;
            } else {
                L++;
            }
        }
        
        if(U-D == 0 && L-R == 0){
            return true;
        }else {
            return false;
        }
    }
}
