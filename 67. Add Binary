class Solution {
    public String addBinary(String a, String b) {
        StringBuilder s = new StringBuilder("");
        int n = a.length()-1;
        int m = b.length()-1;
        int c = 0;
        while(n >= 0 || m >= 0 || c == 1){
            int b1 = 0;
            int b2 = 0;
            if(n>=0){
                if((a.charAt(n)-'0')>0){
                    b1=1;
                }
            }
            if(m>=0){
                if((b.charAt(m)-'0')>0){
                    b2=1;
                }
            }
            int sum = b1+b2+c;
            s.append(sum%2);
            c = sum/2;
            n--;
            m--;
        }
        return s.reverse().toString();
        
    }
}
